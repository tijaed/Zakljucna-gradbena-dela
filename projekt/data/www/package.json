{
    "name": "projekt",
    "version": "1.0.0",
    "scripts": {
        "sass:build": "CHOKIDAR_USEPOLLING=true CHOKIDAR_INTERVAL=100 node ./node_modules/sass/sass.js scss:css --watch",
        "dev": "chokidar \"scss/**/*.scss\" -c \"npm run sass:build\" --initial --poll --silent"
    },
    "dependencies": {
        "bootstrap": "^5.3.0"
    },
    "devDependencies": {
        "sass": "^1.69.0",
        "chokidar-cli": "^3.0.0"
    }
}
